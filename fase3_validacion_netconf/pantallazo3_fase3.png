: rgb(112, 184, 255);">cat</span><span> </span><span class="token token" style="color: rgb(234, 236, 240);">&gt;</span><span> testbed_001V-21.yaml </span><span class="token token" style="color: rgb(234, 236, 240);">&lt;&lt;</span><span> </span><span class="token token" style="color: rgb(155, 233, 99);">'EOF'
</span></span><span class="token token" style="color: rgb(155, 233, 99);">devices:
</span><span class="token token" style="color: rgb(155, 233, 99);">  CSR1kv:
</span><span class="token token" style="color: rgb(155, 233, 99);">    os: iosxe
</span><span class="token token" style="color: rgb(155, 233, 99);">    type: router
</span><span class="token token" style="color: rgb(155, 233, 99);">    credentials:
</span><span class="token token" style="color: rgb(155, 233, 99);">      default:
</span><span class="token token" style="color: rgb(155, 233, 99);">        username: cisco
</span><span class="token token" style="color: rgb(155, 233, 99);">        password: cisco123!
</span><span class="token token" style="color: rgb(155, 233, 99);">    connections:
</span><span class="token token" style="color: rgb(155, 233, 99);">      cli:
</span><span class="token token" style="color: rgb(155, 233, 99);">        protocol: ssh -o KexAlgorithms=diffie-hellman-group14-sha1 -o StrictHostKeyChecking=no
