</span><span class="token token" style="color: rgb(155, 233, 99);">print("-" * 60)
</span><span class="token token" style="color: rgb(155, 233, 99);">
</span><span class="token token" style="color: rgb(155, 233, 99);">criteria = [
</span><span class="token token" style="color: rgb(155, 233, 99);">    ("Hostname corporativo",  got_hostname, EXPECTED["hostname"]),
</span><span class="token token" style="color: rgb(155, 233, 99);">    ("IP Loopback",           got_lb_ip,    EXPECTED["loopback_ip"]),
</span><span class="token token" style="color: rgb(155, 233, 99);">    ("Mascara Loopback",      got_lb_mask,  EXPECTED["loopback_mask"]),
</span><span class="token token" style="color: rgb(155, 233, 99);">    ("Descripcion WAN",       got_desc_wan, EXPECTED["desc_wan"]),
</span><span class="token token" style="color: rgb(155, 233, 99);">    ("Servidor NTP",          got_ntp,      EXPECTED["ntp_server"]),
</span><span class="token token" style="color: rgb(155, 233, 99);">]
</span><span class="token token" style="color: rgb(155, 233, 99);">
</span><span class="token token" style="color: rgb(155, 233, 99);">passed = 0
</span><span class="token token" style="color: rgb(155, 233, 99);">for label, got, expected in criteria:
