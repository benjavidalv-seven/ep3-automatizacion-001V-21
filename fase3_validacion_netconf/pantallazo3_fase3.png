</span><span class="token token" style="color: rgb(155, 233, 99);">}
</span><span class="token token" style="color: rgb(155, 233, 99);">
</span><span class="token token" style="color: rgb(155, 233, 99);">print(f"  Alumno  : {alumno['nombre']} ({alumno['codigo']})")
