</span><span class="token token" style="color: rgb(155, 233, 99);">        reply = m.get_config(source="running", filter=NETCONF_FILTER)
</span><span class="token token" style="color: rgb(155, 233, 99);">        xml_raw = reply.xml
</span><span class="token token" style="color: rgb(155, 233, 99);">        os.makedirs(os.path.dirname(OUTPUT_XML), exist_ok=True)
</span><span class="token token" style="color: rgb(155, 233, 99);">        with open(OUTPUT_XML, "w") as f:
</span><span class="token token" style="color: rgb(155, 233, 99);">            f.write(xml_raw)
</span><span class="token token" style="color: rgb(155, 233, 99);">        print(f"XML guardado en: {OUTPUT_XML}\\n")
</span><span class="token token" style="color: rgb(155, 233, 99);">
</span><span class="token token" style="color: rgb(155, 233, 99);">        root = etree.fromstring(xml_raw.encode())
</span><span class="token token" style="color: rgb(155, 233, 99);">        ns = {
</span><span class="token token" style="color: rgb(155, 233, 99);">            "nc":     "urn:ietf:params:xml:ns:netconf:base:1.0",
