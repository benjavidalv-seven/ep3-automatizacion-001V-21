</span><span class="token token" style="color: rgb(155, 233, 99);">        &lt;name&gt;1&lt;/name&gt;
</span><span class="token token" style="color: rgb(155, 233, 99);">        &lt;description/&gt;
</span><span class="token token" style="color: rgb(155, 233, 99);">      &lt;/GigabitEthernet&gt;
</span><span class="token token" style="color: rgb(155, 233, 99);">      &lt;Loopback&gt;
</span><span class="token token" style="color: rgb(155, 233, 99);">        &lt;name/&gt;
</span><span class="token token" style="color: rgb(155, 233, 99);">        &lt;ip/&gt;
