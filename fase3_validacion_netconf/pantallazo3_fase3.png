: rgb(251, 173, 96);">cd</span><span> ~/ep3-automatizacion-001V-21/fase3_validacion_netconf
</span></span><span class="token token" style="color: rgb(155, 233, 99);">
</span><span class="token token" style="color: rgb(155, 233, 99);"><span>python3 </span><span class="token token" style="color: rgb(234, 236, 240);">&lt;&lt;</span><span> </span><span class="token token" style="color: rgb(155, 233, 99);">'PYEOF'
</span></span><span class="token token" style="color: rgb(155, 233, 99);">contenido = '''#!/usr/bin/env python3
</span><span class="token token" style="color: rgb(155, 233, 99);">"""
</span><span class="token token" style="color: rgb(155, 233, 99);">fase3_validacion_netconf/validacion_netconf.py
</span><span class="token token" style="color: rgb(155, 233, 99);">Validacion via NETCONF - EP3 DRY7122
</span><span class="token token" style="color: rgb(155, 233, 99);">Alumno: Vidal Vidal Benjamin Jose | Codigo: 001V-21
</span><span class="token token" style="color: rgb(155, 233, 99);">"""
</span><span class="token token" style="color: rgb(155, 233, 99);">
</span><span class="token token" style="color: rgb(155, 233, 99);">import socket
</span><span class="token token" style="color: rgb(155, 233, 99);">import os
