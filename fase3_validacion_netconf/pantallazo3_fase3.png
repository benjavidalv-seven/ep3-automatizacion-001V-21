</span><span class="token token" style="color: rgb(155, 233, 99);">        }
</span><span class="token token" style="color: rgb(155, 233, 99);">
</span><span class="token token" style="color: rgb(155, 233, 99);">        def xpath(expr):
</span><span class="token token" style="color: rgb(155, 233, 99);">            results = root.xpath(expr, namespaces=ns)
</span><span class="token token" style="color: rgb(155, 233, 99);">            return results[0].text.strip() if results and results[0].text else None
</span><span class="token token" style="color: rgb(155, 233, 99);">
