</span><span class="token token" style="color: rgb(155, 233, 99);">        got_lb_mask  = xpath(f".//native:native/native:interface/native:Loopback[native:name='{loopback_id}']/native:ip/native:address/native:primary/native:mask")
</span><span class="token token" style="color: rgb(155, 233, 99);">
</span><span class="token token" style="color: rgb(155, 233, 99);">except Exception as e:
</span><span class="token token" style="color: rgb(155, 233, 99);">    print(f"[ERROR] Fallo la conexion NETCONF: {e}")
</span><span class="token token" style="color: rgb(155, 233, 99);">    sys.exit(1)
</span><span class="token token" style="color: rgb(155, 233, 99);">
</span><span class="token token" style="color: rgb(155, 233, 99);">print("-" * 60)
