</span><span class="token token" style="color: rgb(155, 233, 99);">    &lt;/interface&gt;
</span><span class="token token" style="color: rgb(155, 233, 99);">  &lt;/native&gt;
</span><span class="token token" style="color: rgb(155, 233, 99);">&lt;/filter&gt;
</span><span class="token token" style="color: rgb(155, 233, 99);">"""
</span><span class="token token" style="color: rgb(155, 233, 99);">
</span><span class="token token" style="color: rgb(155, 233, 99);">print("Conectando al router via NETCONF (puerto 830)...")
</span><span class="token token" style="color: rgb(155, 233, 99);">
</span><span class="token token" style="color: rgb(155, 233, 99);">try:
</span><span class="token token" style="color: rgb(155, 233, 99);">    with manager.connect(
