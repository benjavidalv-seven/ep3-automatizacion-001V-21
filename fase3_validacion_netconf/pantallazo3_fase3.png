          ease-[cubic-bezier(0.165,0.85,0.45,1)] h-8 w-8 rounded-md backdrop-blur-md _fill_10ocf_9 _ghost_10ocf_96" type="button" aria-label="Copiar al portapapeles" data-state="closed"><div class="relative"><div class="transition-all opacity-100 scale-100" style="width: 20px; height: 20px; display: flex; align-items: center; justify-content: center;"><svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor" xmlns="http://www.w3.org/2000/svg" class="transition-all opacity-100 scale-100" aria-hidden="true" style="flex-shrink: 0;"><path d="M12.5 3A1.5 1.5 0 0 1 14 4.5V6h1.5A1.5 1.5 0 0 1 17 7.5v8a1.5 1.5 0 0 1-1.5 1.5h-8A1.5 1.5 0 0 1 6 15.5V14H4.5A1.5 1.5 0 0 1 3 12.5v-8A1.5 1.5 0 0 1 4.5 3zm1.5 9.5a1.5 1.5 0 0 1-1.5 1.5H7v1.5a.5.5 0 0 0 .5.5h8a.5.5 0 0 0 .5-.5v-8a.5.5 0 0 0-.5-.5H14zM4.5 4a.5.5 0 0 0-.5.5v8a.5.5 0 0 0 .5.5h8a.5.5 0 0 0 .5-.5v-8a.5.5 0 0 0-.5-.5z"></path></svg></div><div class="absolute inset-0 flex items-center justify-center"><div class="transition-all opacity-0 scale-50" style="width: 20px; height: 20px; display: flex; align-items: center; justify-content: center;"><svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor" xmlns="http://www.w3.org/2000/svg" class="transition-all opacity-0 scale-50" aria-hidden="true" style="flex-shrink: 0;"><path d="M15.188 5.11a.5.5 0 0 1 .752.626l-.056.084-7.5 9a.5.5 0 0 1-.738.033l-3.5-3.5-.064-.078a.501.501 0 0 1 .693-.693l.078.064 3.113 3.113 7.15-8.58z"></path></svg></div></div></div></button></div></div><div class="text-text-500 font-small p-3.5 pb-0">bash</div><div class="overflow-x-auto"><pre class="code-block__code !my-0 !rounded-lg !text-sm !leading-relaxed p-3.5" style="color: rgb(234, 236, 240); background: transparent; font-family: var(--font-mono);"><code class="language-bash" style="color: rgb(234, 236, 240); background: transparent; font-family: var(--font-mono); white-space: pre;"><span class="token token" style="color: rgb(155, 233, 99);"><span>python3 </span><span class="token token" style="color: rgb(234, 236, 240);">&lt;&lt;</span><span> </span><span class="token token" style="color: rgb(155, 233, 99);">'PYEOF'
</span></span><span class="token token" style="color: rgb(155, 233, 99);">with open("validacion_netconf.py", "r") as f:
</span><span class="token token" style="color: rgb(155, 233, 99);">    contenido = f.read()
</span><span class="token token" style="color: rgb(155, 233, 99);">
</span><span class="token token" style="color: rgb(155, 233, 99);">contenido = contenido.replace(
</span><span class="token token" style="color: rgb(155, 233, 99);">    'got_ntp      = xpath(".//native:native/native:ntp/native:server/native:server-list/native:ip-address")',
</span><span class="token token" style="color: rgb(155, 233, 99);">    '''ns_ntp = {
</span><span class="token token" style="color: rgb(155, 233, 99);">            "nc":     "urn:ietf:params:xml:ns:netconf:base:1.0",
</span><span class="token token" style="color: rgb(155, 233, 99);">            "native": "http://cisco.com/ns/yang/Cisco-IOS-XE-native",
</span><span class="token token" style="color: rgb(155, 233, 99);">            "ntp":    "http://cisco.com/ns/yang/Cisco-IOS-XE-ntp",
</span><span class="token token" style="color: rgb(155, 233, 99);">        }
</span><span class="token token" style="color: rgb(155, 233, 99);">        ntp_results = root.xpath(".//native:native/native:ntp/ntp:server/ntp:server-list/ntp:ip-address", namespaces=ns_ntp)
</span><span class="token token" style="color: rgb(155, 233, 99);">        got_ntp = ntp_results[0].text.strip() if ntp_results and ntp_results[0].text else None'''
</span><span class="token token" style="color: rgb(155, 233, 99);">)
</span><span class="token token" style="color: rgb(155, 233, 99);">
</span><span class="token token" style="color: rgb(155, 233, 99);">with open("validacion_netconf.py", "w") as f:
</span><span class="token token" style="color: rgb(155, 233, 99);">    f.write(contenido)
</span><span class="token token" style="color: rgb(155, 233, 99);">print("Corregido OK")
</span><span class="token token" style="color: rgb(155, 233, 99);">PYEOF</span></code></pre></div></div>
